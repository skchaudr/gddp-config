# OS
.DS_Store
Thumbs.db

# Secrets — none of these ever belong here
.env
*.key
*.pem
*.token
secrets/

# Editor artifacts
.vscode/
.idea/
.claude/
.aider*
.agents/agents/
*.swp
*~

# Python (scripts/ tooling — venv never committed)
.venv/
__pycache__/
*.pyc

# Graphify output (local, regenerated)
graphify-out/

# Verification receipts: regenerated per-run (timestamps vary). Re-run
# `gddp.py verify node ...` to reproduce. Commit the harness, not its output.
verification/
verification-runtime-live/

# ByteRover — .brv/context-tree/ contains a nested .git managed by brv vc.
# Without these entries, `git add .` fails with "does not have a commit checked out".
.brv/

# vectorcode local index
.vectorcode/

# Remember plugin — local session logs, not repo artifacts
.remember/

# Pi — only understand skill symlinks are tracked under .pi/skills/
.pi/*
!.pi/skills/
.pi/skills/*
!.pi/skills/understand
!.pi/skills/understand-*

# Understand Anything: share the durable graph snapshot, ignore transient work.
.ua/.trash-*/
.ua/intermediate/*
!.ua/intermediate/scan-result.json
