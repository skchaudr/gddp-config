# .understandignore - patterns for files/dirs to exclude from analysis
# Syntax: same as .gitignore (globs, # comments, ! negation, trailing / for dirs)

# --- Runtime/tooling artifacts (always exclude) ---
.pi-subagents/
.ua/
.venv/
.remember/

# --- Regenerated verification receipts (not graph truth) ---
verification/
verification-runtime-live/

# --- Generated graphify output (rebuildable) ---
graphify-out/

# --- Historical archive (tracked but not active source) ---
_archive/

# --- Backup artifacts from node scaffold ---
*.bak

# --- Python bytecode (never analyze) ---
__pycache__/
*.pyc

# --- Test runner artifacts ---
.pytest_cache/

# --- Agent runtime artifacts ---
.agents/agents/

# --- Verification receipts (full set) ---
verification-runtime/

# --- Editor / IDE artifacts ---
.vscode/
.idea/
.claude/
.aider*
*.swp
*~

# --- OS files ---
.DS_Store
Thumbs.db

# --- Secrets (belt and suspenders) ---
.env
*.key
*.pem
*.token
secrets/

# --- Tool-specific local indices ---
.brv/
.vectorcode/